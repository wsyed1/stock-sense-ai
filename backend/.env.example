# StockSense API configuration — copy this file to `.env` and fill in your keys.
#   cd backend && cp .env.example .env
# The real .env is git-ignored and must never be committed.

# --- Required secrets -----------------------------------------------------

# Polygon.io API key (https://polygon.io) — used to fetch stock news.
polygon_api_key=

# OpenAI API key (https://platform.openai.com) — used for sentiment analysis.
openai_api_key=

# --- Optional settings (defaults shown) -----------------------------------

# Model used for sentiment analysis.
# openai_model=gpt-4o-mini

# News articles pulled per ticker from Polygon.
# news_limit=5

# Port the Flask app listens on.
# port=8888

# Scrape full article text and feed it to the model (true/false). Higher
# quality but slower. When newspaper3k is installed it is used; otherwise a
# lightweight requests-based fallback is used.
# enable_scraping=true

# How many articles per ticker to scrape when scraping is enabled.
# scrape_articles_per_ticker=2
